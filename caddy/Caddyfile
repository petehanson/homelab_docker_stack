*.{$HOSTNAME}.duckdns.org, {$HOSTNAME}.duckdns.org {
    tls {
        dns duckdns {$TOKEN}
        resolvers 8.8.8.8
    }

    @root host {$HOSTNAME}.duckdns.org
    handle @root {
        root * /usr/share/caddy
        file_server
        encode gzip zstd
        handle_path /vaultwarden* {
            reverse_proxy vaultwarden:80
        }
    }

    @pihole host pihole.{$HOSTNAME}.duckdns.org
    handle @pihole {
        reverse_proxy pihole:80
    }

    @minio host minio.{$HOSTNAME}.duckdns.org
    handle @minio {
        reverse_proxy minio:9001
    }

    @nomad host nomad.{$HOSTNAME}.duckdns.org
    handle @nomad {
        reverse_proxy nomad_admin:8080
    }

    @dozzle host dozzle.{$HOSTNAME}.duckdns.org
    handle @dozzle {
        reverse_proxy nomad_dozzle:8080
    }

    @immich host immich.{$HOSTNAME}.duckdns.org
    handle @immich {
        reverse_proxy immich_server:2283
    }

    @openwebui host ai.{$HOSTNAME}.duckdns.org
    handle @openwebui {
        reverse_proxy open_webui:8080
    }

    @ollama host ollama.{$HOSTNAME}.duckdns.org
    handle @ollama {
        reverse_proxy ollama:11434
    }

    @searxng host search.{$HOSTNAME}.duckdns.org
    handle @searxng {
        reverse_proxy searxng:8080
    }

    @crafty host crafty.{$HOSTNAME}.duckdns.org
    handle @crafty {
        reverse_proxy https://crafty_container:8443 {
            transport http {
                tls_insecure_skip_verify
            }
            flush_interval -1
        }
    }
}
